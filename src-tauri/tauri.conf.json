{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalBeam",
  "version": "0.1.0",
  "identifier": "app.localbeam",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "LocalBeam",
        "width": 380,
        "height": 560,
        "minWidth": 360,
        "minHeight": 480,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
